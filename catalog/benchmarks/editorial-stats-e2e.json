{
  "scene_id": "bench_ed_stats",
  "duration_s": 5,
  "fps": 60,
  "format_version": 2,
  "personality": "editorial",
  "background": "#d4a43a",
  "layers": [
    {
      "id": "bg",
      "type": "html",
      "depth_class": "background",
      "content": "<div style=\"width:100%;height:100%;background:linear-gradient(180deg, oklch(88% 0.12 82) 0%, oklch(82% 0.16 75) 50%, oklch(76% 0.18 68) 100%)\"></div>"
    },
    {
      "id": "glow",
      "type": "html",
      "depth_class": "background",
      "content": "<div style=\"width:100%;height:100%;display:flex;align-items:center;justify-content:center\"><div style=\"width:600px;height:400px;border-radius:50%;background:radial-gradient(ellipse,oklch(90% 0.12 82 / 60%) 0%,oklch(85% 0.14 78 / 30%) 40%,transparent 70%);filter:blur(40px)\"></div></div>"
    },
    {
      "id": "pill-calls",
      "type": "html",
      "depth_class": "foreground",
      "src": "e2e/assets/stat-calls.html",
      "position": { "x": 590, "y": 320, "w": 420, "h": 100 }
    },
    {
      "id": "pill-emails",
      "type": "html",
      "depth_class": "foreground",
      "src": "e2e/assets/stat-emails.html",
      "position": { "x": 610, "y": 440, "w": 420, "h": 100 }
    }
  ],
  "motion": {
    "groups": [
      {
        "id": "bg-entrance",
        "targets": ["bg"],
        "primitive": "fade-in"
      },
      {
        "id": "glow-entrance",
        "targets": ["glow"],
        "primitive": "fade-in",
        "effects": [
          { "type": "scale", "from": 0.8, "to": 1.0, "duration_ms": 2000, "easing": "ease_out" }
        ]
      },
      {
        "id": "calls-entrance",
        "targets": ["pill-calls"],
        "primitive": "ed-slide-stagger",
        "on_complete": { "emit": "calls_in" },
        "effects": [
          { "type": "scale", "from": 0.92, "to": 1.0, "duration_ms": 800, "easing": "ease_out" }
        ]
      },
      {
        "id": "emails-entrance",
        "targets": ["pill-emails"],
        "primitive": "ed-slide-stagger",
        "delay": { "after": "calls_in", "offset_ms": 200 },
        "effects": [
          { "type": "scale", "from": 0.92, "to": 1.0, "duration_ms": 800, "easing": "ease_out" }
        ]
      }
    ],
    "camera": {
      "moves": [
        { "move": "push_in", "intensity": 0.12, "from": 0, "to": 0.6 },
        { "move": "drift", "intensity": 0.04, "from": 0.6, "to": 1.0 }
      ]
    }
  }
}