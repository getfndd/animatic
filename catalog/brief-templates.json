[
  {
    "template_id": "brand-story",
    "name": "Brand Story",
    "description": "Narrative arc with emotional moments. Slow build, hero reveal, emotional close.",
    "defaults": {
      "style": "intimate",
      "duration_target_s": 45,
      "tone": {
        "mood": "warm",
        "energy": "low"
      }
    },
    "suggested_scene_count": {
      "min": 6,
      "max": 12
    },
    "sections": [
      {
        "label": "Opening",
        "description": "Set the mood — atmospheric shot or provocative question. No product yet.",
        "emphasis": "normal",
        "suggested_layout": "full-bleed",
        "suggested_content_type": "typography",
        "intent_tags": [
          "opening"
        ]
      },
      {
        "label": "Problem",
        "description": "The tension — what's broken, what's missing, what needs to change.",
        "emphasis": "normal",
        "suggested_layout": "hero-center",
        "suggested_content_type": "typography",
        "intent_tags": [
          "emotional"
        ]
      },
      {
        "label": "People",
        "description": "The humans behind the brand. Portraits, team shots, candid moments.",
        "emphasis": "strong",
        "suggested_layout": "split-panel",
        "suggested_content_type": "portrait",
        "intent_tags": [
          "emotional"
        ],
        "repeat": {
          "min": 1,
          "max": 3
        }
      },
      {
        "label": "Vision",
        "description": "The answer — what the brand believes. The product as manifestation.",
        "emphasis": "strong",
        "suggested_layout": "hero-center",
        "suggested_content_type": "product_shot",
        "intent_tags": [
          "hero"
        ]
      },
      {
        "label": "Proof",
        "description": "Evidence — screenshots, metrics, real usage. Ground the vision.",
        "emphasis": "normal",
        "suggested_layout": "masonry-grid",
        "suggested_content_type": "ui_screenshot",
        "intent_tags": [
          "detail"
        ],
        "optional": true,
        "repeat": {
          "min": 1,
          "max": 2
        }
      },
      {
        "label": "Closing",
        "description": "Brand mark + tagline. Emotional resolution.",
        "emphasis": "normal",
        "suggested_layout": "hero-center",
        "suggested_content_type": "brand_mark",
        "intent_tags": [
          "closing"
        ]
      }
    ],
    "example": {
      "project": {
        "title": "Why We Built Harbor",
        "description": "Brand story video for Harbor — a team communication platform built by remote workers, for remote workers."
      },
      "content": {
        "headline": "Connection Shouldn't Be This Hard",
        "sections": [
          {
            "label": "Opening",
            "text": "Every day, 40 million people open a chat app and feel further apart."
          },
          {
            "label": "Problem",
            "text": "Messages get lost. Context disappears. Teams drift."
          },
          {
            "label": "People",
            "text": "We've been there.",
            "assets": [
              "team-founders"
            ]
          },
          {
            "label": "Vision",
            "text": "Harbor — where conversations become connections",
            "assets": [
              "product-hero"
            ]
          },
          {
            "label": "Closing",
            "text": "Harbor. Built remote-first.",
            "assets": [
              "logo"
            ]
          }
        ]
      }
    }
  },
  {
