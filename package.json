{
  "name": "animatic",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "bin": {
    "animatic": "./bin/animatic.mjs"
  },
  "scripts": {
    "sync": "node scripts/sync-to-preset.mjs",
    "sync:dry": "node scripts/sync-to-preset.mjs --dry-run",
    "setup-hook": "bash scripts/setup-hook.sh",
    "start:mcp": "node mcp/index.js",
    "test": "node --test mcp/test/ src/remotion/test/",
    "test:golden": "node --test mcp/test/golden/",
    "test:golden:update": "ANIMATIC_UPDATE_GOLDENS=1 node --test mcp/test/golden/",
    "capture": "node scripts/capture-prototype.mjs",
    "preflight": "node scripts/preflight.mjs",
    "preview": "node scripts/preview.mjs",
    "remotion:studio": "NODE_OPTIONS=\"--dns-result-order=ipv4first\" npx remotion studio",
    "remotion:render": "NODE_OPTIONS=\"--dns-result-order=ipv4first\" npx remotion render",
    "remotion:render:scene": "NODE_OPTIONS=\"--dns-result-order=ipv4first\" npx remotion render Scene --output renders/scene.mp4",
    "remotion:render:sequence": "NODE_OPTIONS=\"--dns-result-order=ipv4first\" npx remotion render Sequence --output renders/sequence.mp4",
    "sizzle": "node scripts/sizzle.mjs",
    "benchmark": "node --test mcp/test/benchmark.test.js"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "ajv": "^8.18.0",
    "dotenv": "^16.4.7",
    "puppeteer": "^24.37.5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@remotion/bundler": "^4.0.431",
    "@remotion/cli": "^4.0.431",
    "motion": "^12.38.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remotion": "^4.0.431"
  }
}
