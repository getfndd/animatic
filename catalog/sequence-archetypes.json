        "duration_pct": 0.25,
        "energy": "medium",
        "camera": { "move": "push_in", "intensity": 0.4 },
        "transition_in": { "type": "focus_dissolve", "duration_ms": 500 },
        "recommended_layers": ["text_hero", "background_ambient"],
        "recommended_primitives": ["mo-text-hero", "cd-typewriter", "as-fadeInUp"]
