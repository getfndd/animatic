        "purpose": "Brief visual tease of the product — enough to intrigue, not explain",
        "duration_pct": 0.25,
        "energy": "high",
        "camera": { "move": "breathe", "intensity": 0.5 },
        "transition_in": { "type": "zoom_crossfade", "duration_ms": 400 },
        "recommended_layers": ["product_screenshot", "ui_overlay", "background_gradient"],
        "recommended_primitives": ["cd-focus-stagger", "mo-scale-entrance", "as-zoomIn"]
