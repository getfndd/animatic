        "energy": "medium",
        "camera": { "move": "static", "intensity": 0 },
        "transition_in": { "type": "crossfade", "duration_ms": 400 },
        "recommended_layers": ["text_hero", "background_solid"],
        "recommended_primitives": ["mo-text-hero", "as-fadeIn", "ed-blur-reveal"]
