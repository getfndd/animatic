{
  "scene_id": "bench_cd_e2e",
  "duration_s": 5,
  "fps": 60,
  "format_version": 2,
  "personality": "cinematic-dark",
  "background": "#0d0d12",
  "layers": [
    {
      "id": "bg",
      "type": "html",
      "depth_class": "background",
      "content": "<div style=\"width:100%;height:100%;background:radial-gradient(ellipse 80% 60% at 50% 50%, oklch(18% 0.025 260), oklch(8% 0.015 260) 70%, #0d0d12)\"></div>"
    },
    {
      "id": "headline",
      "type": "text",
      "depth_class": "foreground",
      "content": "Introducing Aurora",
      "style": {
        "fontFamily": "system-ui, -apple-system, sans-serif",
        "fontSize": 64,
        "fontWeight": 700,
        "color": "oklch(95% 0.01 260)",
        "textAlign": "center",
        "letterSpacing": "-0.02em",
        "lineHeight": 1.05
      },
      "position": { "x": 310, "y": 56, "w": 1300, "h": 100 }
    },
    {
      "id": "tagline",
      "type": "text",
      "depth_class": "foreground",
      "content": "Analytics that see what others miss",
      "style": {
        "fontFamily": "system-ui, -apple-system, sans-serif",
        "fontSize": 21,
        "fontWeight": 400,
        "color": "oklch(55% 0.01 260)",
        "textAlign": "center",
        "letterSpacing": "0.01em"
      },
      "position": { "x": 510, "y": 170, "w": 900, "h": 40 }
    },
    {
      "id": "product",
      "type": "html",
      "depth_class": "midground",
      "src": "e2e/assets/product-frame.html",
      "position": { "x": 430, "y": 240, "w": 1060, "h": 480 }
    },
    {
      "id": "glow",
      "type": "html",
      "depth_class": "background",
      "content": "<div style=\"width:100%;height:100%;display:flex;align-items:center;justify-content:center\"><div style=\"width:700px;height:500px;background:radial-gradient(ellipse, oklch(28% 0.05 260 / 35%), transparent 70%);filter:blur(80px);transform:translateY(60px)\"></div></div>"
    },
    {
      "id": "cta",
      "type": "html",
      "depth_class": "foreground",
      "content": "<div style=\"display:flex;align-items:center;justify-content:center;width:100%;height:100%\"><div style=\"font-family:system-ui,-apple-system,sans-serif;font-size:14px;font-weight:500;letter-spacing:0.04em;color:oklch(90% 0.01 260);border:1px solid oklch(35% 0.01 260);padding:10px 28px;border-radius:8px;background:oklch(16% 0.015 260)\">Start free trial</div></div>",
      "position": { "x": 810, "y": 750, "w": 300, "h": 50 }
    }
  ],
  "motion": {
    "groups": [
      {
        "id": "bg-entrance",
        "targets": ["bg", "glow"],
        "primitive": "fade-in"
      },
      {
        "id": "headline-reveal",
        "targets": ["headline"],
        "primitive": "cd-focus-stagger",
        "on_complete": { "emit": "headline_done" },
        "effects": [
          { "type": "blur", "from": 8, "to": 0, "duration_ms": 600, "easing": "expo_out" },
          { "type": "brightness", "from": 0.3, "to": 1.0, "duration_ms": 800, "easing": "ease_out" }
        ]
      },
      {
        "id": "tagline-entrance",
        "targets": ["tagline"],
        "primitive": "ed-slide-stagger",
        "delay": { "after": "headline_done", "offset_ms": 100 }
      },
      {
        "id": "product-entrance",
        "targets": ["product"],
        "primitive": "cd-focus-stagger",
        "delay": { "after": "headline_done", "offset_ms": 300 },
        "effects": [
          { "type": "scale", "from": 1.03, "to": 1.0, "duration_ms": 1800, "easing": "ease_out" }
        ]
      },
      {
        "id": "cta-entrance",
        "targets": ["cta"],
        "primitive": "fade-in",
        "delay": { "after": "headline_done", "offset_ms": 700 }
      }
    ],
    "camera": {
      "moves": [
        { "move": "push_in", "intensity": 0.3, "from": 0, "to": 0.6 },
        { "move": "drift", "intensity": 0.1, "from": 0.6, "to": 1.0 }
      ],
      "sync": { "peak_at": 0.6, "cue": "headline_done" }
    }
  }
}
