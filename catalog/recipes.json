[
  {
    "id": "cd-focus-reveal",
    "name": "Cinematic Focus Reveal",
    "personality": "cinematic-dark",
    "description": "Hero element emerges through blur with spring settle, supporting elements follow with descending stagger",
    "groups": [
      {
        "role": "hero",
        "primitive": "cd-focus-stagger",
        "stagger": null
      },
      {
        "role": "supporting",
        "primitive": "cd-focus-stagger",
        "delay_after_hero_ms": 200,
        "stagger": {
          "interval_ms": 180,
          "order": "sequential",
          "amplitude": { "curve": "descending", "start": 1.0, "end": 0.6 }
        }
      }
    ],
    "camera_sync": { "peak_at": 0.5, "cue": "hero_done" },
    "default_camera": { "move": "push_in", "intensity": 0.35 }
  },
  {
    "id": "cd-parallax-entrance",
    "name": "Cinematic Parallax Entrance",
    "personality": "cinematic-dark",
    "description": "Depth-staggered entrance where background layers arrive first, foreground last",
    "groups": [
      {
        "role": "background",
        "primitive": "fade-in",
        "stagger": null
      },
      {
        "role": "supporting",
        "primitive": "cd-focus-stagger",
        "delay_after_hero_ms": 300,
        "stagger": {
          "interval_ms": 150,
          "order": "sequential",
          "amplitude": { "curve": "uniform", "start": 1.0, "end": 1.0 }
        }
      },
      {
        "role": "hero",
        "primitive": "cd-focus-stagger",
        "delay_after_hero_ms": 500
      }
    ],
    "camera_sync": null,
    "default_camera": { "move": "drift", "intensity": 0.2 }
  },
  {
    "id": "cd-spring-stagger",
    "name": "Cinematic Spring Stagger",
    "personality": "cinematic-dark",
    "description": "All elements enter with spring physics, staggered from center outward",
    "groups": [
      {
        "role": "*",
        "primitive": "cd-focus-stagger",
        "stagger": {
          "interval_ms": 120,
          "order": "center_out",
          "amplitude": { "curve": "wave", "start": 1.0, "end": 1.0 },
          "settle": { "easing": "spring", "duration_ms": 600 }
        }
      }
    ],
    "camera_sync": null,
    "default_camera": { "move": "push_in", "intensity": 0.25 }
  },
